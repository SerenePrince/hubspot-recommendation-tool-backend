# Server
PORT=3001

# Data root (where vendor/webappanalyzer lives)
# If not set, defaults to ./data/vendor/webappanalyzer/src relative to backend/
DATA_ROOT=./data/vendor/webappanalyzer/src

# Caching
REPORT_CACHE_TTL_MS=300000
REPORT_CACHE_MAX_ENTRIES=200

# Fetch limits
FETCH_TIMEOUT_MS=12000
MAX_FETCH_BYTES=2000000

# Output / debug
NODE_ENV=development
